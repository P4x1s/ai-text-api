# TextAPI Environment Variables

# Your TRON wallet address for receiving USDT payments
MY_TRON_ADDRESS=YOUR_TRON_WALLET_ADDRESS_HERE

# TronGrid API key (get free at https://www.trongrid.io)
TRONGRID_API_KEY=YOUR_TRONGRID_API_KEY_HERE

# AI Provider API Keys (for production use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Database (for production storage)
# DATABASE_URL=postgresql://...

# Redis (for rate limiting)
# REDIS_URL=redis://...
