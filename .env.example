# TextAPI Environment Variables

# ============================================
# AI Provider Configuration
# ============================================
# Choose one: openai, deepseek, qwen, doubao, claude
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (Chinese, very popular)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# Qwen / 通义千问 (Alibaba)
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
QWEN_MODEL=qwen-plus

# Doubao / 豆包 (ByteDance)
DOUBAO_API_KEY=...
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-4k

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-haiku-20240307

# ============================================
# Payment Configuration
# ============================================
# Your TRON wallet address for receiving USDT
MY_TRON_ADDRESS=TBfAn71a2GjcpGtd5noRAE59QnvkEj7uME

# TronGrid API key (get free at https://www.trongrid.io)
TRONGRID_API_KEY=...

# ============================================
# Email Configuration
# ============================================
# Resend API key (get free at https://resend.com)
RESEND_API_KEY=re_...
